{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "dialog:default",
    "fs:default",
    "shell:allow-open",
    "deep-link:default",
    "updater:default",
    "process:allow-restart",
    {
      "identifier": "fs:allow-read-text-file",
      "allow": [
        { "path": "$HOME/*" },
        { "path": "$HOME/**/*" },
        { "path": "$HOME/**/.*" },
        { "path": "$HOME/**/.*/*" },
        { "path": "$HOME/**/.*/**/*" }
      ]
    },
    {
      "identifier": "fs:allow-write-text-file",
      "allow": [
        { "path": "$HOME/*" },
        { "path": "$HOME/**/*" },
        { "path": "$HOME/**/.*" },
        { "path": "$HOME/**/.*/*" },
        { "path": "$HOME/**/.*/**/*" }
      ]
    },
    {
      "identifier": "fs:allow-exists",
      "allow": [
        { "path": "$HOME" },
        { "path": "$HOME/*" },
        { "path": "$HOME/**" },
        { "path": "$HOME/**/*" },
        { "path": "$HOME/**/.*" },
        { "path": "$HOME/**/.*/*" },
        { "path": "$HOME/**/.*/**/*" }
      ]
    },
    {
      "identifier": "fs:allow-mkdir",
      "allow": [
        { "path": "$HOME/*" },
        { "path": "$HOME/**" },
        { "path": "$HOME/**/*" },
        { "path": "$HOME/**/.*" },
        { "path": "$HOME/**/.*/*" }
      ]
    },
    {
      "identifier": "fs:allow-remove",
      "allow": [
        { "path": "$HOME/*" },
        { "path": "$HOME/**/*" },
        { "path": "$HOME/**/.*" },
        { "path": "$HOME/**/.*/*" },
        { "path": "$HOME/**/.*/**/*" }
      ]
    },
    {
      "identifier": "fs:allow-rename",
      "allow": [
        { "path": "$HOME/*" },
        { "path": "$HOME/**/*" },
        { "path": "$HOME/**/.*" },
        { "path": "$HOME/**/.*/*" },
        { "path": "$HOME/**/.*/**/*" }
      ]
    },
    {
      "identifier": "fs:allow-read-dir",
      "allow": [
        { "path": "$HOME" },
        { "path": "$HOME/*" },
        { "path": "$HOME/**" },
        { "path": "$HOME/**/*" },
        { "path": "$HOME/**/.*" },
        { "path": "$HOME/**/.*/*" }
      ]
    },
    {
      "identifier": "fs:allow-watch",
      "allow": [
        { "path": "$HOME/**" },
        { "path": "$HOME/**/*" },
        { "path": "$HOME/**/.*/**/*" }
      ]
    },
    {
      "identifier": "fs:allow-unwatch",
      "allow": [
        { "path": "$HOME/**" },
        { "path": "$HOME/**/*" },
        { "path": "$HOME/**/.*/**/*" }
      ]
    }
  ]
}
