{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "dialog:default",
    "fs:default",
    "shell:allow-open",
    "deep-link:default",
    {
      "identifier": "fs:allow-read-text-file",
      "allow": [
        { "path": "$HOME/Desk/*" },
        { "path": "$HOME/Desk/**/*" },
        { "path": "$HOME/Desk/**/.*" }
      ]
    },
    {
      "identifier": "fs:allow-write-text-file",
      "allow": [
        { "path": "$HOME/Desk/*" },
        { "path": "$HOME/Desk/**/*" },
        { "path": "$HOME/Desk/**/.*" }
      ]
    },
    {
      "identifier": "fs:allow-exists",
      "allow": [
        { "path": "$HOME/Desk" },
        { "path": "$HOME/Desk/*" },
        { "path": "$HOME/Desk/**/*" },
        { "path": "$HOME/Desk/**/.*" }
      ]
    },
    {
      "identifier": "fs:allow-mkdir",
      "allow": [
        { "path": "$HOME/Desk" },
        { "path": "$HOME/Desk/*" },
        { "path": "$HOME/Desk/**/*" }
      ]
    },
    {
      "identifier": "fs:allow-remove",
      "allow": [
        { "path": "$HOME/Desk/*" },
        { "path": "$HOME/Desk/**/*" },
        { "path": "$HOME/Desk/**/.*" }
      ]
    },
    {
      "identifier": "fs:allow-rename",
      "allow": [
        { "path": "$HOME/Desk/*" },
        { "path": "$HOME/Desk/**/*" },
        { "path": "$HOME/Desk/**/.*" }
      ]
    },
    {
      "identifier": "fs:allow-read-dir",
      "allow": [
        { "path": "$HOME/Desk" },
        { "path": "$HOME/Desk/*" },
        { "path": "$HOME/Desk/**/*" }
      ]
    },
    {
      "identifier": "fs:allow-watch",
      "allow": [
        { "path": "$HOME/Desk" },
        { "path": "$HOME/Desk/**/*" }
      ]
    },
    {
      "identifier": "fs:allow-unwatch",
      "allow": [
        { "path": "$HOME/Desk" },
        { "path": "$HOME/Desk/**/*" }
      ]
    }
  ]
}
