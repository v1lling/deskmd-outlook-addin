{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "dialog:default",
    "fs:default",
    {
      "identifier": "fs:allow-home-read-recursive",
      "allow": [{ "path": "$HOME/Orbit/**" }]
    },
    {
      "identifier": "fs:allow-home-write-recursive",
      "allow": [{ "path": "$HOME/Orbit/**" }]
    },
    "fs:allow-home-meta-recursive",
    "fs:allow-mkdir",
    "fs:allow-remove",
    "fs:allow-rename",
    "fs:allow-exists"
  ]
}
