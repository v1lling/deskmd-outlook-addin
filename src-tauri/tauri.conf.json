{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Desk",
  "version": "0.3.3",
  "identifier": "ch.sascha.desk",
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["desk"]
      }
    },
    "updater": {
      "endpoints": [
        "https://github.com/v1lling/deskmd-releases/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEREMjA1M0M5NzdFMUNGRDYKUldUV3orRjN5Vk1nM1R2WjUvc2hnanUvZEc3ODVPSXdMQ0lQeGlLYjk2T28wcDhhdDN5KythOXoK"
    }
  },
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3001",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Desk",
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
